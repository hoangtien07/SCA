# ── AI APIs ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith Tracing (Prompt #02) ────────────────────────────────────────────
# Optional. Get key at https://smith.langchain.com/
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=skincare-ai
LANGSMITH_TRACING=false

# ── Vector database ──────────────────────────────────────────────────────────
# Local dev: leave blank (uses ./data/knowledge_base/)
CHROMA_PERSIST_DIR=./data/knowledge_base

# Production: fill in Qdrant Cloud credentials
QDRANT_URL=https://xxx.qdrant.io
QDRANT_API_KEY=

# ── Embeddings (Prompt #04) ───────────────────────────────────────────────────
# "local" uses NeuML/pubmedbert-base-embeddings (no API cost, ~400MB download)
# "openai" uses text-embedding-3-small ($0.02/1M tokens)
EMBEDDING_PROVIDER=local
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ── Redis / Celery (Prompt #06) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Semantic Cache (Prompt #07) ───────────────────────────────────────────────
CACHE_ENABLED=false
CACHE_RETRIEVAL_TTL=86400
CACHE_REGIMEN_TTL=43200
CACHE_SIMILARITY_THRESHOLD=0.92

# ── Database (Supabase) ───────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=

# ── App settings ─────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO
MAX_PAPERS_PER_QUERY=200         # papers to collect per search query
EMBEDDING_MODEL=text-embedding-3-small
REASONING_MODEL=claude-sonnet-4-6-20251101
VISION_MODEL=gpt-4o
RETRIEVAL_TOP_K=8                # chunks returned per query
CHUNK_SIZE=512                   # tokens per chunk
CHUNK_OVERLAP=64                 # overlap between chunks

# ── CV Datasets (Prompt #09) ──────────────────────────────────────────────────
CV_DATASETS_DIR=./data/cv_datasets
VISION_EVAL_SAMPLE_SIZE=100

# ── XAI (Prompt #12) ──────────────────────────────────────────────────────────
XAI_ENABLED=false
XAI_NUM_SAMPLES=500
XAI_SURROGATE_MODEL=mobilenet_v2
