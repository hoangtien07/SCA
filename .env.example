# ── AI APIs ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Vector database ──────────────────────────────────────────────────────────
# Local dev: leave blank (uses ./data/knowledge_base/)
CHROMA_PERSIST_DIR=./data/knowledge_base

# Production: fill in Qdrant Cloud credentials
QDRANT_URL=https://xxx.qdrant.io
QDRANT_API_KEY=

# ── Database (Supabase) ───────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=

# ── App settings ─────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO
MAX_PAPERS_PER_QUERY=200         # papers to collect per search query
EMBEDDING_MODEL=text-embedding-3-small
REASONING_MODEL=claude-sonnet-4-6-20251101
VISION_MODEL=gpt-4o
RETRIEVAL_TOP_K=8                # chunks returned per query
CHUNK_SIZE=512                   # tokens per chunk
CHUNK_OVERLAP=64                 # overlap between chunks
